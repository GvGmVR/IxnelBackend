{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "types": ["node"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*", "Todelete/lib/astra.ts", "Todelete/config/db.ts", "Todelete/config/env.ts", "Todelete/controllers/auth.controller.ts", "Todelete/controllers/editor.controller.ts", "Todelete/controllers/feedback.controller.ts", "Todelete/controllers/newsletter.controller.ts", "Todelete/controllers/pipeline.controller.ts", "Todelete/controllers/project.controller.ts", "Todelete/controllers/news.controller.ts"],
  "exclude": ["node_modules", "dist"]
}
